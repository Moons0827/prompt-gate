# ─────────────────────────────────────────────────────────
# prompt-gate 설정
#
# ★ 이 파일을 .env 로 복사해서 쓴다.
#     cp env.example .env
#
# ★ 모델 ID는 제공사 문서에서 직접 확인하고 적는다.
#   코드에 기본값이 없다. 비워 두면 실행이 막힌다 (의도된 것).
#   날짜가 박힌 스냅샷 ID를 쓴다. 'latest' 별칭은 코드가 거부한다.
# ─────────────────────────────────────────────────────────

# anthropic | openai | null
# null 은 디버그용이다. 통제 조건이 아니다.
GENERATOR=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=

# 재현성을 위해 0 고정
TEMPERATURE=0.0
MAX_TOKENS=600
TIMEOUT_S=30.0

DB_URL=sqlite:///./promptgate.db
